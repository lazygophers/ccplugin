{
  "name": "ccplugin-market",
  "owner": {
    "name": "lazygophers",
    "email": "admin@lazygophers.dev"
  },
  "metadata": {
    "description": "Claude Code 插件市场 - 提供常用插件和开发模板",
    "pluginRoot": "./plugins"
  },
  "plugins": [
    {
      "name": "git",
      "source": "./plugins/tools/git",
      "description": "Git 操作插件 - 提供完整的 Git 操作支持，包括提交管理、Pull Request 管理和 .gitignore 管理",
      "author": {
        "name": "lazygophers",
        "email": "admin@lazygophers.dev"
      },
      "homepage": "https://github.com/lazygophers/ccplugin/tree/master/plugins/tools/git",
      "repository": "https://github.com/lazygophers/ccplugin/tree/master/plugins/tools/git",
      "license": "AGPL-3.0-or-later",
      "keywords": [
        "git",
        "commit",
        "pr",
        "pull-request",
        "gitignore",
        "version-control",
        "workflow"
      ]
    },
    {
      "name": "deepresearch",
      "source": "./plugins/tools/deepresearch",
      "description": "深度研究插件 - 基于图思维框架的多智能体深度研究系统。支持多领域深度调查、引用验证、知识合成和专业报告生成",
      "author": {
        "name": "lazygophers",
        "email": "admin@lazygophers.dev"
      },
      "homepage": "https://github.com/lazygophers/ccplugin/tree/master/plugins/tools/deepresearch",
      "repository": "https://github.com/lazygophers/ccplugin/tree/master/plugins/tools/deepresearch",
      "license": "AGPL-3.0-or-later",
      "keywords": [
        "deep",
        "research",
        "investigation",
        "analysis",
        "citation",
        "multi-agent",
        "got",
        "graph-of-thoughts",
        "synthesis",
        "validation"
      ]
    },
    {
      "name": "version",
      "source": "./plugins/tools/version",
      "description": "版本号管理插件 - 提供 SemVer 版本管理，支持自动版本更新和手动版本设置。通过 Claude Code Hooks 自动检测任务完成并更新构建版本号",
      "author": {
        "name": "lazygophers",
        "email": "admin@lazygophers.dev"
      },
      "homepage": "https://github.com/lazygophers/ccplugin/tree/master/plugins/tools/version",
      "repository": "https://github.com/lazygophers/ccplugin/tree/master/plugins/tools/version",
      "license": "AGPL-3.0-or-later",
      "keywords": [
        "version",
        "semver",
        "versioning",
        "release",
        "management",
        "automation",
        "hooks"
      ]
    },
    {
      "name": "notify",
      "source": "./plugins/tools/notify",
      "description": "系统通知插件 - 通过系统通知向用户实时提示会话状态变更、权限请求等重要事件。跨平台支持 macOS、Linux、Windows",
      "author": {
        "name": "lazygophers",
        "email": "admin@lazygophers.dev"
      },
      "homepage": "https://github.com/lazygophers/ccplugin/tree/master/plugins/tools/notify",
      "repository": "https://github.com/lazygophers/ccplugin/tree/master/plugins/tools/notify",
      "license": "AGPL-3.0-or-later",
      "keywords": [
        "notification",
        "system-notification",
        "hook",
        "event",
        "macos",
        "linux",
        "windows"
      ]
    },
    {
      "name": "llms",
      "source": "./plugins/llms",
      "description": "llms.txt 标准插件 - 通过 Agent 自动生成符合 llms.txt 规范的文件。支持项目扫描、混合链接管理和 LLM 友好文档生成",
      "author": {
        "name": "lazygophers",
        "email": "admin@lazygophers.dev"
      },
      "homepage": "https://github.com/lazygophers/ccplugin/tree/master/plugins/llms",
      "repository": "https://github.com/lazygophers/ccplugin/tree/master/plugins/llms",
      "license": "AGPL-3.0-or-later",
      "keywords": [
        "llms",
        "llms.txt",
        "documentation",
        "llm",
        "context",
        "markdown",
        "agent",
        "standard"
      ]
    },
    {
      "name": "trellisx",
      "source": "./plugins/tools/trellisx",
      "description": "Trellisx — Trellis 增强改造工具: 跑一次 trellisx-apply 把 强推task / subtask拆分 / worktree隔离 / plan→exec→check→finish闭环 / task.md看板 五维度注入 .trellis (workflow + config.yaml 生命周期 hook + scripts); 含 trellisx-flow 强制task闭环 / orchestrate 编排 / workspace 看板 / spec 破坏式重构",
      "author": {
        "name": "lazygophers",
        "email": "admin@lazygophers.dev"
      },
      "homepage": "https://github.com/lazygophers/ccplugin/tree/master/plugins/tools/trellisx",
      "repository": "https://github.com/lazygophers/ccplugin/tree/master/plugins/tools/trellisx",
      "license": "AGPL-3.0-or-later",
      "keywords": [
        "trellis",
        "task-orchestration",
        "subtask",
        "agent-team",
        "worktree",
        "sub-agent",
        "spec",
        "workflow",
        "prompt-injection",
        "planning",
        "mermaid"
      ]
    },
    {
      "name": "cortex",
      "source": "./plugins/tools/cortex",
      "description": "知识库 + 记忆管理插件 - 双层 vault, 5 级记忆 (遗忘曲线), 8 skill: schema/ingest/lint/extract/history-digest/context-digest/evolve/recall",
      "category": "tools",
      "strict": false
    },
    {
      "name": "template",
      "source": "./plugins/template",
      "description": "插件开发模板 - 快速创建新插件的基础结构",
      "author": {
        "name": "lazygophers",
        "email": "admin@lazygophers.dev"
      },
      "homepage": "https://github.com/lazygophers/ccplugin/tree/master/plugins/template",
      "repository": "https://github.com/lazygophers/ccplugin/tree/master/plugins/template",
      "license": "AGPL-3.0-or-later",
      "keywords": [
        "template",
        "boilerplate",
        "scaffold"
      ]
    }
  ]
}
