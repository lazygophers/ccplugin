{
  "name": "llms",
  "version": "0.0.195.43",
  "description": "llms.txt 标准插件 - 通过 Agent 自动生成符合 llmstxt.org 规范的文件",
  "author": {
    "name": "CCPlugin Contributors",
    "email": "info@lazygophers.com",
    "url": "https://github.com/lazygophers"
  },
  "homepage": "https://github.com/lazygophers/ccplugin",
  "repository": "https://github.com/lazygophers/ccplugin",
  "license": "AGPL-3.0-or-later",
  "keywords": [
    "llms",
    "llms.txt",
    "documentation",
    "llm",
    "context",
    "markdown",
    "agent"
  ],
  "agents": [
    "./agents/llms-generator.md",
    "./agents/llms-validator.md"
  ],
  "skills": [
    "./skills/llms-spec",
    "./skills/llms-generate"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "当本会话将要处理项目代码、文档、配置、API、CLI、Agent、Skill、Hook、MCP 或使用方式变更时，在任务完成前检查是否需要创建、更新或完善对应的 llms.txt 与 .llms.json。若变更影响项目对 LLM 的可读入口、文档索引、示例、配置说明或插件组件清单，使用 llms-spec 与 llms-generate 两个 Agent 按 llmstxt.org 规范更新 llms.txt，并按验证规范完成自检。仅提供上下文提醒，不阻塞无关任务。"
          }
        ]
      }
    ]
  }
}
