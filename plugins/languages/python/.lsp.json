{
  "python": {
    "command": "pylsp",
    "args": [],
    "extensionToLanguage": {
      ".py": "python"
    },
    "settings": {
      "pylsp": {
        "plugins": {
          "ruff": {
            "enabled": true,
            "lineLength": 88,
            "format": ["I"],
            "lint": {
              "select": ["E", "F", "W", "I", "N", "UP", "ANN", "B", "SIM"]
            }
          },
          "pycodestyle": { "enabled": false },
          "pyflakes": { "enabled": false },
          "flake8": { "enabled": false },
          "black": { "enabled": false },
          "autopep8": { "enabled": false },
          "isort": { "enabled": false },
          "mccabe": {
            "enabled": true,
            "threshold": 10
          },
          "rope": { "enabled": false }
        }
      }
    },
    "restartOnCrash": true,
    "maxRestarts": 5,
    "startupTimeout": 10000,
    "shutdownTimeout": 5000
  }
}
