{
  "c": {
    "command": "clangd",
    "args": [
      "--background-index",
      "-j=4",
      "--clang-tidy",
      "--header-insertion=iwyu",
      "--completion-style=detailed",
      "--function-arg-placeholders",
      "--fallback-style=llvm",
      "--pch-storage=memory",
      "--log=error"
    ],
    "extensionToLanguage": {
      ".c": "c",
      ".h": "c"
    },
    "restartOnCrash": true,
    "maxRestarts": 5,
    "startupTimeout": 10000,
    "shutdownTimeout": 5000
  }
}
