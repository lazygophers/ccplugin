      "description": "查看当前通知配置",
      "hooks": [
        {
          "type": "command",
          "command": "uv run --directory ${CLAUDE_PLUGIN_ROOT} ./scripts/main.py config",
          "timeout": 10
        }
      ]
    }
  ],
