      {
        "hooks": [
          {
            "type": "command",
            "command": "PLUGIN_NAME=notify uv run --directory ${CLAUDE_PLUGIN_ROOT} ./scripts/main.py hooks",
            "timeout": 10
          }
        ]
      }
    ],
