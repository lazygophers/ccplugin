{
  "name": "trellisx",
  "description": "Trellisx — Trellis 任务编排扩展: spec 破坏式优化 skill + 任务拆分 skill + UserPromptSubmit prompt hook 注入编排硬规",
  "author": {
    "name": "lazygophers",
    "email": "admin@lazygophers.dev",
    "url": "https://github.com/lazygophers"
  },
  "homepage": "https://github.com/lazygophers/ccplugin/tree/master/plugins/tools/trellisx",
  "repository": "https://github.com/lazygophers/ccplugin/tree/master/plugins/tools/trellisx",
  "license": "AGPL-3.0-or-later",
  "agents": [
    "./agents/trellisx-spec.md"
  ],
  "skills": [
    "./skills/trellisx-enforce",
    "./skills/trellisx-spec",
    "./skills/trellisx-orchestrate"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "statusMessage": "trellisx · 启用 agent-teams + 检测 trellis 项目",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "statusMessage": "trellisx · 检查 trellis 触发关键词",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/user-prompt-submit.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "statusMessage": "trellisx · 校验回复前缀标记",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/stop-check.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "statusMessage": "trellisx · 提醒 sub-agent worktree 合并清理",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/subagent-stop.sh"
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          {
            "type": "command",
            "statusMessage": "trellisx · 提醒为 task 创建 worktree",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/task-created.sh"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "statusMessage": "trellisx · 校验 task worktree 已清理",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/task-completed.sh"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "statusMessage": "trellisx · 写盘 worktree 提醒",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/permission-request.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "statusMessage": "trellisx · 记录残留 worktree",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/session-end.sh"
          }
        ]
      }
    ]
  },
  "keywords": [
    "trellis",
    "task-orchestration",
    "subtask",
    "agent-team",
    "worktree",
    "sub-agent",
    "spec",
    "workflow",
    "prompt-injection"
  ]
}
