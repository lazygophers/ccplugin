{
  "name": "task",
  "version": "0.0.193",
  "description": "Task 任务管理插件 - 提供任务规划、执行、验证和迭代的完整生命周期管理",
  "author": {
    "name": "lazygophers",
    "email": "admin@lazygophers.dev",
    "url": "https://github.com/lazygophers"
  },
  "homepage": "https://github.com/lazygophers/ccplugin/tree/master/plugins/tools/task",
  "repository": "https://github.com/lazygophers/ccplugin/tree/master/plugins/tools/task",
  "license": "AGPL-3.0-or-later",
  "keywords": [
    "task",
    "task-management",
    "planning",
    "execution",
    "verification",
    "workflow",
    "state-machine",
    "dag"
  ],
  "agents": [
    "./agents/adjust.md",
    "./agents/align.md",
    "./agents/done.md",
    "./agents/explore.md",
    "./agents/plan.md",
    "./agents/verify.md"
  ],
  "skills": "./skills/",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PLUGIN_NAME=task uv run --directory ${CLAUDE_PLUGIN_ROOT} ./scripts/main.py hooks"
          }
        ]
      }
    ],
    "UserPromptSubmit": []
  }
}
