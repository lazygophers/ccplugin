%% Task 插件组件架构图
%% 展示 Skills 层级、Explorer 体系、辅助组件关系

graph TB
    subgraph TaskPlugin["Task Plugin"]
        direction TB

        subgraph Core["核心编排"]
            Loop["loop<br/>迭代式任务编排引擎"]
            Execute["execute<br/>任务执行调度"]
        end

        subgraph LifecycleSkills["生命周期 Skills"]
            Planner["planner<br/>计划设计"]
            Verifier["verifier<br/>结果验证"]
            Adjuster["adjuster<br/>失败调整"]
            Finalizer["finalizer<br/>资源清理"]
        end

        subgraph OptionalSkills["可选 Skills"]
            PromptOpt["prompt-optimizer<br/>提示词优化"]
            DeepIter["deep-iteration<br/>深度迭代"]
        end

        subgraph ExplorerFamily["Explorer 探索体系"]
            ExGeneral["explorer-general<br/>通用项目探索"]
            ExCode["explorer-code<br/>代码结构探索"]
            ExFrontend["explorer-frontend<br/>前端探索"]
            ExBackend["explorer-backend<br/>后端探索"]
            ExAPI["explorer-api<br/>API探索"]
            ExDB["explorer-database<br/>数据库探索"]
            ExDeps["explorer-dependencies<br/>依赖探索"]
            ExInfra["explorer-infrastructure<br/>基础设施探索"]
            ExTest["explorer-test<br/>测试探索"]
            ExMem["explorer-memory-integration<br/>记忆集成探索"]
        end

        subgraph Infrastructure["基础设施"]
            Checkpoint["checkpoint<br/>检查点管理"]
            MemBridge["memory-bridge<br/>记忆桥接"]
            CtxVersion["context-versioning<br/>上下文版本化"]
            Observe["observability<br/>可观测性"]
            ParaSched["parallel-scheduler<br/>并行调度"]
        end

        subgraph Governance["治理与合规"]
            HITL["hitl<br/>人工审批"]
            Hooks["hooks<br/>生命周期钩子"]
        end
    end

    %% 核心编排关系
    Loop -->|"调度"| Planner
    Loop -->|"调度"| Execute
    Loop -->|"调度"| Verifier
    Loop -->|"调度"| Adjuster
    Loop -->|"调度"| Finalizer

    %% 可选阶段
    Loop -.->|"可选"| PromptOpt
    Loop -.->|"可选"| DeepIter

    %% Execute 使用 Explorer
    Execute -.->|"按需调用"| ExGeneral
    ExGeneral -->|"继承"| ExCode
    ExGeneral -->|"继承"| ExFrontend
    ExGeneral -->|"继承"| ExBackend
    ExGeneral -->|"继承"| ExAPI
    ExGeneral -->|"继承"| ExDB
    ExGeneral -->|"继承"| ExDeps
    ExGeneral -->|"继承"| ExInfra
    ExGeneral -->|"继承"| ExTest
    ExGeneral -->|"继承"| ExMem

    %% 基础设施支撑
    Loop -->|"保存/恢复"| Checkpoint
    Loop -->|"记忆读写"| MemBridge
    Loop -->|"快照管理"| CtxVersion
    Loop -->|"指标收集"| Observe
    Execute -->|"并行控制"| ParaSched

    %% 治理
    Planner -.->|"关键决策"| HITL
    Loop -->|"事件通知"| Hooks

    %% 外部依赖
    DeepRes["deepresearch:deep-research<br/>（外部插件）"]
    Loop -.->|"可选"| DeepRes

    %% 样式
    classDef core fill:#4A90D9,stroke:#2C5F8A,color:#fff
    classDef lifecycle fill:#7BC67E,stroke:#4A8A4D,color:#fff
    classDef optional fill:#F5A623,stroke:#C47D1A,color:#fff
    classDef explorer fill:#9B59B6,stroke:#6C3483,color:#fff
    classDef infra fill:#95A5A6,stroke:#5D6D7E,color:#fff
    classDef govern fill:#E74C3C,stroke:#A93226,color:#fff
    classDef external fill:#BDC3C7,stroke:#7F8C8D,color:#333

    class Loop,Execute core
    class Planner,Verifier,Adjuster,Finalizer lifecycle
    class PromptOpt,DeepIter optional
    class ExGeneral,ExCode,ExFrontend,ExBackend,ExAPI,ExDB,ExDeps,ExInfra,ExTest,ExMem explorer
    class Checkpoint,MemBridge,CtxVersion,Observe,ParaSched infra
    class HITL,Hooks govern
    class DeepRes external
