%% MindFlow 数据/上下文流向图
%% 展示 6 个必传字段的生命周期、中间产物流转、各 Skill 的输入输出

graph TB
    subgraph UserInput["用户输入"]
        UserTask["user_task<br/>用户原始任务描述"]
        WorkDir["working_directory<br/>工作目录"]
        ProjectPath["project_path<br/>项目根目录"]
    end

    subgraph PhaseInit["Initialization"]
        GenId["生成 task_id"]
        SetIter["iteration = 0"]
        ResetCtx["context = {}"]
        ScanResidual["扫描残留计划"]
    end

    subgraph PhasePromptOpt["PromptOptimization（条件触发）"]
        PODecompose["TaskDecomposition<br/>任务分解+边界定义"]
        PODialog["ClarificationDialog<br/>澄清对话"]
        POSpec["SpecGeneration<br/>生成规格说明"]
        POPersist["PromptPersistence<br/>写入 prompt.md"]
        POConfirm["UserConfirmation<br/>用户确认 A/B/C"]
    end

    subgraph ContextFields["6 个必传上下文字段"]
        F1["project_path"]
        F2["task_id"]
        F3["iteration"]
        F4["plan_md_path"]
        F5["working_directory"]
        F6["user_task"]
    end

    subgraph PhasePlan["Planning"]
        L1["L1: 项目全局理解<br/>README/CLAUDE.md"]
        L2["L2: 规范与记忆<br/>.claude/rules/"]
        L3["L3: 目标文件<br/>Glob/Grep定位"]
        MECE["MECE 分解 + DAG"]
        WritePlanFile["写入计划文件"]
    end

    subgraph PhaseExec["Execution"]
        ReadPlan["读取计划文件"]
        SkillCall["Skill() 调用"]
        UpdateTask["更新任务状态"]
    end

    subgraph PhaseVerify["Verification"]
        ReadPlanV["读取计划 + 验收标准"]
        Stage1["Stage1: 功能合规"]
        Stage2["Stage2: 代码质量"]
        Stage3["Stage3: 深度校验"]
        ScoreOut["quality_score + status"]
    end

    subgraph PhaseFinal["Cleanup"]
        CleanPlan["删除计划文件"]
        CleanCheckpoint["清理检查点"]
        CleanArtifacts["清理5类中间产物"]
        SaveMem["保存情节记忆"]
        Retro["微回顾"]
    end

    subgraph Artifacts["中间产物生命周期"]
        direction LR
        PlanFile[".claude/tasks/{task_id}/plan.md<br/>Planning 创建 → Cleanup 删除"]
        CheckpointFile[".claude/checkpoints/{task_id}.json<br/>Execution 创建 → Cleanup 删除"]
        MetadataFile[".claude/tasks/{task_id}/metadata.json<br/>Initialization 创建 → Cleanup 删除"]
        TasksFile[".claude/tasks/{task_id}/tasks.json<br/>Planning 创建 → Cleanup 删除"]
        ApprovalLog[".claude/tasks/{task_id}/approval-log.json<br/>Planning 创建 → Cleanup 删除"]
        ContextSnap[".claude/context/{task_id}/v*.json<br/>ContextVersioning 创建 → Cleanup 删除"]
        PromptFile[".claude/tasks/{task_id}/prompt.md<br/>PromptOptimization 创建 → Cleanup 删除"]
    end

    subgraph Memory["记忆层"]
        EpisodicMem["情节记忆<br/>iteration/duration/score<br/>永久保留"]
        ProjectMem["项目记忆<br/>.claude/memory/<br/>永久保留"]
    end

    %% 用户输入 → 初始化
    UserTask --> GenId
    WorkDir --> F5
    ProjectPath --> F1

    %% 初始化产出
    GenId --> F2
    SetIter --> F3
    ScanResidual -.->|"清理残留"| PlanFile

    %% PromptOptimization 流程
    UserTask -->|"原始提示词"| PODecompose
    PODecompose --> PODialog
    PODialog --> POSpec
    POSpec --> POPersist
    POPersist -->|"生成"| PromptFile
    POPersist --> POConfirm
    POConfirm -->|"A/B:更新"| F6

    %% 上下文字段传递
    F1 & F2 & F3 & F4 & F5 & F6 -->|"每次 Skill() 调用<br/>必须全量传递"| SkillCall
    F1 & F2 & F3 & F4 & F5 & F6 -->|"传递"| L1

    %% Planning 流程
    L1 --> L2 --> L3 --> MECE --> WritePlanFile
    WritePlanFile -->|"生成"| PlanFile
    WritePlanFile -->|"设置"| F4
    UserTask --> F6

    %% Execution 流程
    PlanFile -->|"读取"| ReadPlan
    ReadPlan --> SkillCall
    SkillCall -->|"执行结果"| UpdateTask
    UpdateTask -->|"更新状态"| PlanFile
    SkillCall -->|"保存"| CheckpointFile

    %% Verification 流程
    PromptFile -->|"对照验证"| ReadPlanV
    PlanFile -->|"读取"| ReadPlanV
    ReadPlanV --> Stage1 --> Stage2 --> Stage3 --> ScoreOut
    ScoreOut -->|"passed"| QualityGate{"QualityGate"}
    ScoreOut -->|"failed"| PhaseAdjust["Adjustment"]
    QualityGate -->|"达标"| PhaseFinal
    QualityGate -->|"不达标"| PhasePromptOpt2["PromptOptimization"]

    %% Cleanup 流程
    PromptFile -->|"删除"| CleanPlan
    PlanFile -->|"删除"| CleanPlan
    CheckpointFile -->|"删除"| CleanCheckpoint
    ApprovalLog & ContextSnap -->|"删除"| CleanArtifacts
    CleanArtifacts --> SaveMem
    SaveMem -->|"写入"| EpisodicMem
    SaveMem --> Retro
    Retro -->|"追加"| EpisodicMem

    %% 记忆交互
    ProjectMem -->|"L2 读取"| L2
    EpisodicMem -->|"历史参考"| L2

    %% 任务状态文件
    PhaseFinal -->|"创建"| MetadataFile

    %% 样式
    classDef input fill:#3498DB,stroke:#2471A3,color:#fff
    classDef field fill:#E67E22,stroke:#BA6512,color:#fff
    classDef phase fill:#2ECC71,stroke:#1E8449,color:#fff
    classDef artifact fill:#F39C12,stroke:#B7770A,color:#fff
    classDef memory fill:#9B59B6,stroke:#6C3483,color:#fff

    class UserTask,WorkDir,ProjectPath input
    class F1,F2,F3,F4,F5,F6 field
    class L1,L2,L3,MECE,WritePlanFile,ReadPlan,SkillCall,UpdateTask,ReadPlanV,Stage1,Stage2,Stage3,ScoreOut,CleanPlan,CleanCheckpoint,CleanArtifacts,SaveMem,Retro,GenId,SetIter,ResetCtx,ScanResidual phase
    class PlanFile,CheckpointFile,MetadataFile,TasksFile,ApprovalLog,ContextSnap,PromptFile artifact
    class PODecompose,PODialog,POSpec,POPersist,POConfirm phase
    class EpisodicMem,ProjectMem memory
