%%{init: {'theme':'dark','flowchart': {'nodeSpacing': 22,'rankSpacing': 86,'curve': 'basis','padding': 12},'themeVariables': {'background':'#0f172a','mainBkg':'#0f172a','primaryColor':'#111827','primaryTextColor':'#e5e7eb','primaryBorderColor':'#334155','lineColor':'#94a3b8','secondaryColor':'#0b1220','tertiaryColor':'#111827','clusterBkg':'#0b1220','clusterBorder':'#334155','clusterTextColor':'#e5e7eb','edgeLabelBackground':'#0b1220','fontFamily':'ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, Helvetica, Arial, "Apple Color Emoji", "Segoe UI Emoji"'},'themeCSS':'svg{background-color:#0f172a !important;}'}}%%
flowchart TB
    %% =============================================================================
    %% MindFlow Loop - 迭代式任务编排引擎完整执行流程
    %% 基于 PDCA 循环的智能任务管理系统
    %% 阶段使用语义化命名（非严格顺序执行）
    %% =============================================================================

    %% 节点样式定义
    classDef phaseNode fill:#1e293b,stroke:#38bdf8,stroke-width:2px,color:#e2e8f0,rx:6,ry:6
    classDef optionalNode fill:#2a1d0b,stroke:#f59e0b,stroke-width:2px,color:#fef3c7,rx:6,ry:6,stroke-dasharray: 5 5
    classDef decisionNode fill:#3b0a28,stroke:#fb7185,stroke-width:2px,color:#ffe4e6,rx:6,ry:6
    classDef violationNode fill:#3f1d1d,stroke:#ef4444,stroke-width:2px,color:#fee2e2,rx:6,ry:6
    classDef startNode fill:#0f2a1f,stroke:#34d399,stroke-width:3px,color:#d1fae5,rx:10,ry:10
    classDef endNode fill:#2e1065,stroke:#a78bfa,stroke-width:3px,color:#ede9fe,rx:10,ry:10
    classDef contextNode fill:#0b1f1a,stroke:#22c55e,stroke-width:1px,color:#d1fae5,font-size:11px,rx:6,ry:6
    classDef errorNode fill:#3f1d1d,stroke:#f87171,stroke-width:2px,color:#fee2e2,rx:6,ry:6
    classDef skipNode fill:#111827,stroke:#f59e0b,stroke-width:2px,color:#fde68a,rx:10,ry:10,stroke-dasharray: 6 4

    %% =============================================================================
    %% 开始节点
    %% =============================================================================
    Start([开始: 用户任务])

    %% =============================================================================
    %% Initialization: 初始化
    %% =============================================================================
    subgraph Init[Initialization: 初始化]
        direction TB
        Init_1[检查点恢复检测]
        Init_2{存在检查点?}
        Init_3[恢复状态<br/>iter/context/plan]
        Init_Jump[恢复跳转<br/>从 checkpoint 进入对应阶段]
        Init_4[正常初始化<br/>iter=0, stalled=0]
        Init_5[生成任务ID: task_id]
        Init_6[创建状态文件<br/>.claude/tasks/{task_id}/status.json]
        Init_7[残留清理+30天过期清理]
        Init_8[加载记忆<br/>episodic + semantic]
        Init_9[资源检查<br/>ListSkills + ListAgents]

        Init_1 --> Init_2
        Init_2 -->|是| Init_3
        Init_2 -->|否| Init_4
        Init_4 --> Init_5
        Init_3 --> Init_Jump
        Init_Jump --> Init_5
        Init_5 --> Init_6
        Init_6 --> Init_7
        Init_7 --> Init_8
        Init_8 --> Init_9
    end

    Start --> Init_1
    Init_Jump -.恢复.-> Plan_Entry
    Init_Jump -.恢复.-> Exec_Entry
    Init_Jump -.恢复.-> Verify_Entry
    Init_Jump -.恢复.-> Adjust_Entry

    %% =============================================================================
    %% PromptOptimization: 提示词优化（可选，仅首次）
    %% =============================================================================
    subgraph PromptOpt[PromptOptimization: 提示词优化 - 可选]
        direction TB
        PO_1{iter=0?}
        PO_2[prompt-optimizer<br/>质量评估]
        PO_3{score < 8?}
        PO_4[5W1H 提问<br/>AskUserQuestion]
        PO_5{score < 6?}
        PO_6[必要时 WebSearch<br/>最佳实践]
        PO_7[生成优化提示词]
        PO_8{用户选择<br/>A/B/C}
        PO_Skip([跳过])

        PO_1 -->|是| PO_2
        PO_1 -->|否| PO_Skip
        PO_2 --> PO_3
        PO_3 -->|是| PO_4
        PO_3 -->|否| PO_5
        PO_4 --> PO_5
        PO_5 -->|是| PO_6
        PO_5 -->|否| PO_7
        PO_6 --> PO_7
        PO_7 --> PO_8
    end

    Init_9 --> PO_1
    PO_Skip --> DR_Entry
    PO_8 -->|A/B:继续| DR_Entry
    PO_8 -->|C:重做| PO_7

    %% =============================================================================
    %% DeepResearch: 深度研究（可选）
    %% =============================================================================
    subgraph DeepRes[DeepResearch: 深度研究 - 可选]
        direction TB
        DR_Entry{需要深度研究?}
        DR_1[复杂度评估<br/>4维度]
        DR_2{≥8?}
        DR_3{6-8?}
        DR_4[AskUserQuestion<br/>是否研究]
        DR_5{用户选择?}
        DR_6[deepresearch<br/>deep-research]
        DR_7[并行探索<br/>选型/架构/陷阱]
        DR_8[整合结果<br/>发现/建议/风险]
        DR_9[写入<br/>context.research_report]
        DR_Skip([跳过])

        DR_Entry -->|是| DR_1
        DR_Entry -->|否| DR_Skip
        DR_1 --> DR_2
        DR_2 -->|是| DR_6
        DR_2 -->|否| DR_3
        DR_3 -->|是| DR_4
        DR_3 -->|否| DR_Skip
        DR_4 --> DR_5
        DR_5 -->|是| DR_6
        DR_5 -->|否| DR_Skip
        DR_6 --> DR_7
        DR_7 --> DR_8
        DR_8 --> DR_9
    end

    PO_Skip --> DR_Entry
    DR_9 --> Plan_Entry
    DR_Skip --> Plan_Entry

    %% =============================================================================
    %% Planning: 计划设计与确认
    %% =============================================================================
    subgraph Plan[Planning: 计划设计与确认]
        direction TB
        Plan_Entry[iteration 加一]
        Plan_Mode[模式判定<br/>iter>1且trigger?]
        Plan_1[task:planner<br/>含格式化+写文件]
        Plan_Violation[违规检测<br/>Planner完整性]
        Plan_2[处理 planner 返回结果<br/>提取 plan_md_path]
        Plan_3{tasks为空?}
        Plan_SkipExec([跳过执行])
        Plan_5{auto_approve?}
        Plan_6[自动批准]
        Plan_7[AskUserQuestion<br/>请求批准]
        Plan_8{用户批准?}
        Plan_9[提取反馈<br/>replan_trigger=user]
        Plan_10[save_checkpoint]
        Plan_Context[Context-6<br/>project_path/...]

        Plan_Entry --> Plan_Mode
        Plan_Mode --> Plan_1
        Plan_1 --> Plan_Violation
        Plan_Violation --> Plan_2
        Plan_2 --> Plan_3
        Plan_3 -->|是| Plan_SkipExec
        Plan_3 -->|否| Plan_5
        Plan_5 -->|true| Plan_6
        Plan_5 -->|false| Plan_7
        Plan_7 --> Plan_8
        Plan_8 -->|是| Plan_10
        Plan_8 -->|否| Plan_9
        Plan_9 -.-> Plan_Entry
        Plan_6 --> Plan_Context
        Plan_10 --> Plan_Context
    end

    Plan_Context --> Exec_Entry
    Plan_SkipExec --> Final_Entry

    %% =============================================================================
    %% Execution: 任务执行
    %% =============================================================================
    subgraph Exec[Execution: 任务执行]
        direction TB
        Exec_Entry[读取计划文件]
        Exec_1[复杂度评估]
        Exec_2[冲突检测<br/>file_map]
        Exec_3[并行度≤2<br/>batch]
        Exec_4[选批次<br/>无冲突]
        Exec_5[按 DAG<br/>依赖执行]
        Exec_Run[调用 Agent/Skill<br/>执行 task]
        Exec_Context[Context-6+<br/>... + task参数]

        Exec_6[执行完整性检查]
        Exec_7{交付物完整?}
        Exec_8[标记 incomplete]
        Exec_9[自动重新调用 Agent]
        Exec_10{重试次数<2?}
        Exec_11[标记失败]

        Exec_12[更新计划文件状态]
        Exec_13[更新任务状态文件]
        Exec_14[save_checkpoint<br/>phase=execution]
        Exec_Violation[违规检测: Skill/Agent工具调用]

        Exec_Entry --> Exec_1
        Exec_1 --> Exec_2
        Exec_2 --> Exec_3
        Exec_3 --> Exec_4
        Exec_4 --> Exec_5
        Exec_5 --> Exec_Run
        Exec_Run --> Exec_Violation
        Exec_Violation --> Exec_Context
        Exec_Context --> Exec_6
        Exec_6 --> Exec_7
        Exec_7 -->|是| Exec_12
        Exec_7 -->|否| Exec_8
        Exec_8 --> Exec_9
        Exec_9 --> Exec_10
        Exec_10 -->|是| Exec_Run
        Exec_10 -->|否| Exec_11
        Exec_11 --> Exec_12
        Exec_12 --> Exec_13
        Exec_13 --> Exec_14
    end

    Exec_14 --> Verify_Entry

    %% =============================================================================
    %% Verification: 结果验证
    %% =============================================================================
    subgraph Verify[Verification: 结果验证]
        direction TB
        Verify_Entry[前置条件检查]
        Verify_Check{所有任务完成?}
        Verify_Error[触发错误: 未完成就验证]

        Verify_1[强制: 调用 task:verifier]
        Verify_Context[Context-6<br/>project_path/...]

        Verify_2[Stage 1: 验收标准检查]
        Verify_3[Stage 2: 回归测试]
        Verify_4[Stage 3: 深度校验]
        Verify_5[质量评分: 7维度加权]
        Verify_6{status?<br/>passed/suggestions/failed}
        Verify_10{质量达标?}
        Verify_Qual[质量阈值<br/>迭代1=60, 迭代2=75<br/>迭代3=85, 迭代4+=90]

        Verify_11[更新 plan frontmatter]
        Verify_12[更新任务状态文件]
        Verify_13[save_checkpoint<br/>phase=verification]

        Verify_Entry --> Verify_Check
        Verify_Check -->|否| Verify_Error
        Verify_Check -->|是| Verify_1
        Verify_1 --> Verify_Context
        Verify_Context --> Verify_2
        Verify_2 --> Verify_3
        Verify_3 --> Verify_4
        Verify_4 --> Verify_5
        Verify_5 --> Verify_6
        Verify_6 --> Verify_10
        Verify_10 -->|达标| Verify_11
        Verify_10 -->|不达标| Verify_Fail[-> Adjustment]
        Verify_11 --> Verify_12
        Verify_12 --> Verify_13
    end

    Verify_Route[结果路由<br/>passed→Finalization<br/>suggestions→Planning<br/>failed→Adjustment]
    Verify_13 --> Verify_Route
    Verify_Route -->|passed| Final_Entry
    Verify_Route -->|suggestions| Plan_Entry
    Verify_Route -->|failed| Adjust_Entry
    Verify_Fail --> Adjust_Entry

    %% =============================================================================
    %% Adjustment: 失败调整（条件触发）
    %% =============================================================================
    subgraph Adjust[Adjustment: 失败调整]
        direction TB
        Adjust_Entry[记忆检索: 提取失败原因]
        Adjust_1[search_failure_patterns<br/>检索]
        Adjust_2[调用 task:adjuster]
        Adjust_Context[Context-失败信息<br/>... + failed_tasks + reason]
        Adjust_3[分析失败原因]
        Adjust_4[决定恢复策略<br/>strategy]
        Adjust_5[save_checkpoint<br/>phase=adjustment]
        Adjust_6{HITL 审批}
        Adjust_7{风险评估}
        Adjust_8[指数退避: backoff_seconds]

        Adjust_Level[升级策略<br/>L1 retry 0s<br/>L1.5 self-healing 0s<br/>L2 debug 2s<br/>L2.5 micro-replan 4s<br/>L3 full replan 8s<br/>L4 ask_user]
        Adjust_Route[路由<br/>retry/debug→Execution<br/>replan→Planning<br/>ask_user→用户]

        Adjust_Stuck[停滞检测:<br/>连续3次相同错误<br/>振荡检测A→B→A→B]

        Adjust_Entry --> Adjust_1
        Adjust_1 --> Adjust_2
        Adjust_2 --> Adjust_Context
        Adjust_Context --> Adjust_3
        Adjust_3 --> Adjust_4
        Adjust_4 --> Adjust_5
        Adjust_5 --> Adjust_6
        Adjust_6 --> Adjust_7
        Adjust_7 --> Adjust_8
        Adjust_8 --> Adjust_Level
        Adjust_Level --> Adjust_Route
    end

    Adjust_User([用户决策])
    Adjust_Route -->|retry/debug| Exec_Entry
    Adjust_Route -->|replan| Plan_Entry
    Adjust_Route -->|ask_user| Adjust_User

    %% =============================================================================
    %% Finalization: 完成清理
    %% =============================================================================
    subgraph Final[Finalization: 完成清理]
        direction TB
        Final_Entry[前置条件: 验证通过或确认]
        Final_0[更新任务状态文件<br/>status→completed/failed]
        Final_1[调用 task:finalizer]
        Final_Context[Context-6<br/>project_path/...]

        Final_2[模式提取<br/>extract_failure_patterns]
        Final_3[检查点清理: cleanup_checkpoint]
        Final_4[微回顾: 有效实践/需改进/下次注意]
        Final_5[记忆保存: save_task_episode]
        Final_6[短期记忆清理<br/>cleanup_working_memory]
        Final_7[最终报告]

        Final_Cleanup[6类中间产物清理:<br/>计划文件+检查点+审批日志<br/>+指标数据+上下文快照+草稿]

        Final_Entry --> Final_0
        Final_0 --> Final_1
        Final_1 --> Final_Context
        Final_Context --> Final_2
        Final_2 --> Final_3
        Final_3 --> Final_4
        Final_4 --> Final_5
        Final_5 --> Final_6
        Final_6 --> Final_7
        Final_7 --> Final_Cleanup
    end

    Final_Cleanup --> End

    %% =============================================================================
    %% 结束节点
    %% =============================================================================
    End([结束: 任务完成])

    %% =============================================================================
    %% 附录入口
    %% =============================================================================
    Appendix([附录: 说明与图例])

    End --> Appendix
    Appendix --> V_Title
    V_Title --> C_Title
    C_Title --> L_Title

    %% =============================================================================
    %% 辅助说明图
    %% =============================================================================
    subgraph Violations[违规检测系统]
        direction TB
        V_Title[四大违规检测点]
        V1[Planner内部流程检测]
        V2[Skill/Agent工具调用检测]
        V3[Verifier调用检测]
        V4[Finalizer调用检测]
        V_Title --> V1
        V_Title --> V2
        V_Title --> V3
        V_Title --> V4
    end

    subgraph ContextSpec[上下文传递规范]
        direction TB
        C_Title[每次调用必须显式传递]
        C_Rule[核心原则: 不依赖会话上下文]
        C_Fields[6个必传字段<br/>project_path/task_id/iteration<br/>plan_md_path/working_directory/user_task]
        C_Warning[遗漏任何字段将导致无法正确定位]
        C_Title --> C_Rule
        C_Rule --> C_Fields
        C_Fields --> C_Warning
    end

    subgraph Legend[图例说明]
        direction TB
        L_Title[节点类型]
        L1[常规阶段]
        L2[可选阶段 - 虚线边框]
        L3[决策节点]
        L4[违规检测 - 红色]
        L5[开始/结束]
        L6[上下文说明 - 绿色]

        L_Title --> L1
        L_Title --> L2
        L_Title --> L3
        L_Title --> L4
        L_Title --> L5
        L_Title --> L6
    end

    %% =============================================================================
    %% 应用样式类
    %% =============================================================================

    %% Initialization 节点
    class Init_1,Init_3,Init_4,Init_5,Init_6,Init_7,Init_8,Init_9 phaseNode

    %% PromptOptimization 节点（可选）
    class PO_2,PO_4,PO_6,PO_7 optionalNode

    %% DeepResearch 节点（可选）
    class DR_1,DR_6,DR_7,DR_8 optionalNode

    %% Planning 节点
    class Plan_Entry,Plan_1,Plan_2,Plan_6,Plan_10 phaseNode

    %% Execution 节点
    class Exec_Entry,Exec_1,Exec_2,Exec_3,Exec_4,Exec_5,Exec_Run,Exec_12,Exec_13,Exec_14 phaseNode

    %% Verification 节点
    class Verify_Entry,Verify_2,Verify_3,Verify_4,Verify_5,Verify_11,Verify_12,Verify_13 phaseNode

    %% Adjustment 节点
    class Adjust_Entry,Adjust_3,Adjust_4,Adjust_5,Adjust_8 phaseNode

    %% Finalization 节点
    class Final_Entry,Final_0,Final_2,Final_3,Final_4,Final_5,Final_6,Final_7 phaseNode

    %% 决策节点
    class Init_2,PO_1,PO_3,PO_5,PO_8,DR_Entry,DR_2,DR_3,DR_5,Plan_3,Plan_5,Plan_8,Exec_7,Exec_10,Verify_Check,Verify_6,Verify_10,Adjust_6,Adjust_7 decisionNode

    %% 违规检测节点
    class Plan_Violation,Exec_Violation,Verify_1,Adjust_2,Final_1,V1,V2,V3,V4 violationNode

    %% 上下文说明节点
    class Init_Jump,Plan_Mode,Plan_Context,Exec_Context,Verify_Context,Verify_Route,Adjust_Context,Adjust_Level,Adjust_Route,Final_Context,Verify_Qual,Adjust_Stuck,Final_Cleanup,C_Fields contextNode

    %% 开始结束节点
    class Start startNode
    class PO_Skip,DR_Skip,Plan_SkipExec skipNode
    class Verify_Fail,Verify_Error,C_Warning errorNode
    class End endNode

    %% 额外节点
    class Adjust_User optionalNode

    %% 可选阶段容器
    class PromptOpt,DeepRes optionalNode

    %% 附录节点
    class Appendix contextNode

    %% 全局连线样式
    linkStyle default stroke:#94a3b8,stroke-width:1.5px
