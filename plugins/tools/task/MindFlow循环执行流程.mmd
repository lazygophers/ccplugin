flowchart TB
    %% =============================================================================
    %% MindFlow Loop - 迭代式任务编排引擎完整执行流程
    %% 基于 PDCA 循环的智能任务管理系统
    %% =============================================================================

    %% 节点样式定义
    classDef phaseNode fill:#1e293b,stroke:#38bdf8,stroke-width:2px,color:#e2e8f0,rx:6,ry:6
    classDef optionalNode fill:#2a1d0b,stroke:#f59e0b,stroke-width:2px,color:#fef3c7,rx:6,ry:6,stroke-dasharray: 5 5
    classDef decisionNode fill:#3b0a28,stroke:#fb7185,stroke-width:2px,color:#ffe4e6,rx:6,ry:6
    classDef violationNode fill:#3f1d1d,stroke:#ef4444,stroke-width:2px,color:#fee2e2,rx:6,ry:6
    classDef startNode fill:#0f2a1f,stroke:#34d399,stroke-width:3px,color:#d1fae5,rx:10,ry:10
    classDef endNode fill:#2e1065,stroke:#a78bfa,stroke-width:3px,color:#ede9fe,rx:10,ry:10
    classDef contextNode fill:#0b1f1a,stroke:#22c55e,stroke-width:1px,color:#d1fae5,font-size:11px,rx:6,ry:6
    classDef errorNode fill:#3f1d1d,stroke:#f87171,stroke-width:2px,color:#fee2e2,rx:6,ry:6
    classDef skipNode fill:#111827,stroke:#f59e0b,stroke-width:2px,color:#fde68a,rx:10,ry:10,stroke-dasharray: 6 4

    %% =============================================================================
    %% 开始节点
    %% =============================================================================
    Start([开始: 用户任务])

    %% =============================================================================
    %% 阶段1: 初始化 (Phase 1: Initialization)
    %% =============================================================================
    subgraph P1[阶段1: 初始化]
        direction TB
        P1_1[检查点恢复检测]
        P1_2{存在检查点?}
        P1_3[恢复状态<br/>iter/context/plan]
        P1_Jump[恢复跳转<br/>从 checkpoint 进入对应阶段]
        P1_4[正常初始化<br/>iter=0, stalled=0]
        P1_5[生成任务ID: task_id]
        P1_6[创建状态文件<br/>.claude/task/task_id.json]
        P1_7[30天自动清理过期状态]
        P1_8[加载记忆<br/>episodic + semantic]
        P1_9[资源检查<br/>ListSkills + ListAgents]

        P1_1 --> P1_2
        P1_2 -->|是| P1_3
        P1_2 -->|否| P1_4
        P1_4 --> P1_5
        P1_3 --> P1_Jump
        P1_Jump --> P1_5
        P1_5 --> P1_6
        P1_6 --> P1_7
        P1_7 --> P1_8
        P1_8 --> P1_9
    end

    Start --> P1_1
    P1_Jump -.恢复.-> P4_Entry
    P1_Jump -.恢复.-> P5_Entry
    P1_Jump -.恢复.-> P6_Entry
    P1_Jump -.恢复.-> P7_Entry

    %% =============================================================================
    %% 阶段2: 提示词优化 (Phase 2: Prompt Optimization) - 仅首次
    %% =============================================================================
    subgraph P2[阶段2: 提示词优化-仅首次]
        direction TB
        P2_1{iter=0?}
        P2_2[prompt-optimizer<br/>质量评估]
        P2_3{score小于24?}
        P2_4[5W1H 提问<br/>AskUserQuestion]
        P2_5{score小于18?}
        P2_6[必要时 WebSearch<br/>最佳实践]
        P2_7[生成优化提示词]
        P2_8{用户选择<br/>A/B/C}
        P2_Skip([跳过 P2])

        P2_1 -->|是| P2_2
        P2_1 -->|否| P2_Skip
        P2_2 --> P2_3
        P2_3 -->|是| P2_4
        P2_3 -->|否| P2_5
        P2_4 --> P2_5
        P2_5 -->|是| P2_6
        P2_5 -->|否| P2_7
        P2_6 --> P2_7
        P2_7 --> P2_8
    end

    P1_9 --> P2_1
    P2_Skip --> P3_Entry
    P2_8 -->|A/B:继续| P3_Entry
    P2_8 -->|C:重做| P2_7

    %% =============================================================================
    %% 阶段3: 深度研究 (Phase 3: Deep Research) - 可选
    %% =============================================================================
    subgraph P3[阶段3: 深度研究-可选]
        direction TB
        P3_Entry{需要深度研究?}
        P3_1[复杂度评估<br/>4维度]
        P3_2{≥8?}
        P3_3{6-8?}
        P3_4[AskUserQuestion<br/>是否研究]
        P3_5{用户选择?}
        P3_6[deepresearch<br/>deep-research]
        P3_7[并行探索<br/>选型/架构/陷阱]
        P3_8[整合结果<br/>发现/建议/风险]
        P3_9[写入<br/>context.research_report]
        P3_Skip([跳过 P3])

        P3_Entry -->|是| P3_1
        P3_Entry -->|否| P3_Skip
        P3_1 --> P3_2
        P3_2 -->|是| P3_6
        P3_2 -->|否| P3_3
        P3_3 -->|是| P3_4
        P3_3 -->|否| P3_Skip
        P3_4 --> P3_5
        P3_5 -->|是| P3_6
        P3_5 -->|否| P3_Skip
        P3_6 --> P3_7
        P3_7 --> P3_8
        P3_8 --> P3_9
    end

    P2_Skip --> P3_Entry
    P3_9 --> P4_Entry
    P3_Skip --> P4_Entry

    %% =============================================================================
    %% 阶段4: 计划设计与确认 (Phase 4: Planning & Confirmation)
    %% =============================================================================
    subgraph P4[阶段4: 计划设计与确认]
        direction TB
        P4_Entry[iteration 加一]
        P4_Mode[模式判定<br/>iter大于1且trigger?]
        P4_1[task:planner]
        P4_Violation[违规检测<br/>Planner完整性]
        P4_2[处理 planner 问题]
        P4_3{tasks为空?}
        P4_SkipExec([跳过执行])
        P4_4[task:plan-formatter]
        P4_5{auto_approve?}
        P4_6[自动批准]
        P4_7[AskUserQuestion<br/>请求批准]
        P4_8{用户批准?}
        P4_9[提取反馈<br/>replan_trigger=user]
        P4_10[save_checkpoint]
        P4_Context[Context-6<br/>project_path/...]

        P4_Entry --> P4_Mode
        P4_Mode --> P4_1
        P4_1 --> P4_Violation
        P4_Violation --> P4_2
        P4_2 --> P4_3
        P4_3 -->|是| P4_SkipExec
        P4_3 -->|否| P4_4
        P4_4 --> P4_5
        P4_5 -->|true| P4_6
        P4_5 -->|false| P4_7
        P4_7 --> P4_8
        P4_8 -->|是| P4_10
        P4_8 -->|否| P4_9
        P4_9 -.-> P4_Entry
        P4_6 --> P4_Context
        P4_10 --> P4_Context
    end

    P4_Context --> P5_Entry
    P4_SkipExec --> P8_Entry

    %% =============================================================================
    %% 阶段5: 任务执行 (Phase 5: Execution)
    %% =============================================================================
    subgraph P5[阶段5: 任务执行]
        direction TB
        P5_Entry[读取计划文件]
        P5_1[复杂度评估]
        P5_2[冲突检测<br/>file_map]
        P5_3[并行度≤2<br/>batch]
        P5_4[选批次<br/>无冲突]
        P5_5[按 DAG<br/>依赖执行]
        P5_Exec[调用 Agent<br/>执行 task]
        P5_Context[Context-6+<br/>... + task参数]

        P5_6[执行完整性检查]
        P5_7{交付物完整?}
        P5_8[标记 incomplete]
        P5_9[自动重新调用 Agent]
        P5_10{重试次数小于2?}
        P5_11[标记失败]

        P5_12[更新任务状态文件<br/>.claude/tasks/*.json]
        P5_13[更新任务状态文件]
        P5_14[save_checkpoint<br/>phase=execution]
        P5_Violation[违规检测点: Skill工具调用检测]

        P5_Entry --> P5_1
        P5_1 --> P5_2
        P5_2 --> P5_3
        P5_3 --> P5_4
        P5_4 --> P5_5
        P5_5 --> P5_Exec
        P5_Exec --> P5_Violation
        P5_Violation --> P5_Context
        P5_Context --> P5_6
        P5_6 --> P5_7
        P5_7 -->|是| P5_12
        P5_7 -->|否| P5_8
        P5_8 --> P5_9
        P5_9 --> P5_10
        P5_10 -->|是| P5_Exec
        P5_10 -->|否| P5_11
        P5_11 --> P5_12
        P5_12 --> P5_13
        P5_13 --> P5_14
    end

    P5_14 --> P6_Entry

    %% =============================================================================
    %% 阶段6: 结果验证 (Phase 6: Verification)
    %% =============================================================================
    subgraph P6[阶段6: 结果验证]
        direction TB
        P6_Entry[前置条件检查]
        P6_Check{所有任务完成?}
        P6_Error[触发错误: 未完成就验证]

        P6_1[强制: 调用 task:verifier skill]
        P6_Context[Context-6<br/>project_path/...]

        P6_2[Stage 1: 验收标准检查]
        P6_3[Stage 2: 回归测试]
        P6_4[Stage 3: 深度校验]
        P6_5[质量评分: 7维度加权]
        P6_6{status?<br/>passed/suggestions/failed}
        P6_10{质量达标?}
        P6_Qual[质量阈值<br/>迭代1=60, 迭代2=75<br/>迭代3=85, 迭代4及以上=90]

        P6_11[更新 plan frontmatter]
        P6_12[更新任务状态文件]
        P6_13[save_checkpoint<br/>phase=verification]

        P6_Entry --> P6_Check
        P6_Check -->|否| P6_Error
        P6_Check -->|是| P6_1
        P6_1 --> P6_Context
        P6_Context --> P6_2
        P6_2 --> P6_3
        P6_3 --> P6_4
        P6_4 --> P6_5
        P6_5 --> P6_6
        P6_6 --> P6_10
        P6_10 -->|达标| P6_11
        P6_10 -->|不达标| P6_Fail[-> 失败调整]
        P6_11 --> P6_12
        P6_12 --> P6_13
    end

    P6_Route[结果路由<br/>passed→P8 / suggestions→P4 / failed→P7]
    P6_13 --> P6_Route
    P6_Route -->|passed| P8_Entry
    P6_Route -->|suggestions| P4_Entry
    P6_Route -->|failed| P7_Entry
    P6_Fail --> P7_Entry

    %% =============================================================================
    %% 阶段7: 失败调整 (Phase 7: Adjustment)
    %% =============================================================================
    subgraph P7[阶段7: 失败调整]
        direction TB
        P7_Entry[记忆检索: 提取失败原因]
        P7_1[search_failure_patterns<br/>检索]
        P7_2[调用 task:adjuster skill]
        P7_Context[Context-失败信息<br/>... + failed_tasks + reason]
        P7_3[分析失败原因]
        P7_4[决定恢复策略<br/>strategy]
        P7_5[save_checkpoint<br/>phase=adjustment]
        P7_6{HITL 审批}
        P7_7{风险评估}
        P7_8[指数退避: backoff_seconds]

        P7_Level[5级升级策略-摘要<br/>L1 retry 0s<br/>L2 debug 2s<br/>L3 replan 4s<br/>L4 ask_user<br/>L5 escalate]
        P7_Route[路由<br/>retry/debug→P5<br/>replan→P4<br/>ask_user→用户<br/>escalate→高级]

        P7_Stuck[停滞检测:<br/>连续3次相同错误<br/>连续3次重规划相似度大于80%]

        P7_Entry --> P7_1
        P7_1 --> P7_2
        P7_2 --> P7_Context
        P7_Context --> P7_3
        P7_3 --> P7_4
        P7_4 --> P7_5
        P7_5 --> P7_6
        P7_6 --> P7_7
        P7_7 --> P7_8
        P7_8 --> P7_Level
        P7_Level --> P7_Route
    end

    P7_User([用户决策])
    P7_Escalate([高级 Agent])
    P7_Route -->|retry/debug| P5_Entry
    P7_Route -->|replan| P4_Entry
    P7_Route -->|ask_user| P7_User
    P7_Route -->|escalate| P7_Escalate

    %% =============================================================================
    %% 阶段8: 完成清理 (Phase 8: Finalization)
    %% =============================================================================
    subgraph P8[阶段8: 完成清理]
        direction TB
        P8_Entry[前置条件: 验证通过或确认]
        P8_1[调用 task:finalizer]
        P8_Context[Context-6<br/>project_path/...]

        P8_2[模式提取<br/>extract_failure_patterns]
        P8_3[检查点清理: cleanup_checkpoint]
        P8_4[记忆保存: save_task_episode]
        P8_5[短期记忆清理<br/>cleanup_working_memory]
        P8_6[更新任务状态文件]
        P8_7[最终报告]

        P8_Cleanup[临时文件清理规则:<br/>计划文件+检查点+短期记忆<br/>+任务状态30天+中间产物]

        P8_Entry --> P8_1
        P8_1 --> P8_Context
        P8_Context --> P8_2
        P8_2 --> P8_3
        P8_3 --> P8_4
        P8_4 --> P8_5
        P8_5 --> P8_6
        P8_6 --> P8_7
        P8_7 --> P8_Cleanup
    end

    P8_Cleanup --> End

    %% =============================================================================
    %% 结束节点
    %% =============================================================================
    End([结束: 任务完成])

    %% =============================================================================
    %% 附录入口（连接辅助说明，保证单图连通）
    %% =============================================================================
    Appendix([附录: 说明与图例])

    End --> Appendix
    Appendix --> V_Title
    V_Title --> C_Title
    C_Title --> ST_Title
    ST_Title --> L_Title

    %% =============================================================================
    %% 辅助说明图
    %% =============================================================================
    subgraph Violations[违规检测系统]
        direction TB
        V_Title[四大违规检测点]
        V1[1. Planner内部流程检测]
        V2[2. Skill工具调用检测]
        V3[3. Verifier调用检测]
        V4[4. Finalizer调用检测]
        V_Title --> V1
        V_Title --> V2
        V_Title --> V3
        V_Title --> V4
    end

    subgraph Context说明[上下文传递规范]
        direction TB
        C_Title[每次调用必须显式传递]
        C_Rule[核心原则: 不依赖会话上下文]
        C_Fields[6个必传字段]
        C_Warning[遗漏任何字段将导致无法正确定位]
        C_Title --> C_Rule
        C_Rule --> C_Fields
        C_Fields --> C_Warning
    end

    subgraph StateTransitions[状态转换图]
        direction TB
        ST_Title[MindFlow 状态转换]
        ST[P4: 计划设计]
        ST1[P5: 任务执行]
        ST2[P6: 结果验证]
        ST3[P7: 失败调整]
        ST4[P8: 完成清理]
        ST_User([用户决策])

        ST -->|用户批准| ST1
        ST1 -->|完成| ST2
        ST2 -->|passed| ST4
        ST2 -->|suggestions| ST
        ST2 -->|failed| ST3
        ST3 -->|retry或debug| ST1
        ST3 -->|replan| ST
        ST3 -->|ask_user| ST_User
    end

    subgraph Legend[图例说明]
        direction TB
        L_Title[节点类型]
        L1[常规阶段]
        L2[可选阶段]
        L3[决策节点]
        L4[违规检测]
        L5[开始/结束]
        L6[上下文说明]

        L_Title --> L1
        L_Title --> L2
        L_Title --> L3
        L_Title --> L4
        L_Title --> L5
        L_Title --> L6
    end

    %% =============================================================================
    %% 应用样式类
    %%

    %% 阶段节点
    class P1_1,P1_3,P1_4,P1_5,P1_6,P1_7,P1_8,P1_9 phaseNode
    class P2_2,P2_4,P2_6,P2_7 optionalNode
    class P3_1,P3_6,P3_7,P3_8 optionalNode
    class P4_Entry,P4_1,P4_2,P4_4,P4_6,P4_10 phaseNode
    class P5_Entry,P5_1,P5_2,P5_3,P5_4,P5_5,P5_Exec,P5_12,P5_13,P5_14 phaseNode
    class P6_Entry,P6_2,P6_3,P6_4,P6_5,P6_11,P6_12,P6_13 phaseNode
    class P7_Entry,P7_3,P7_4,P7_5,P7_8 phaseNode
    class P8_Entry,P8_2,P8_3,P8_4,P8_5,P8_6,P8_7 phaseNode

    %% 决策节点
    class P1_2,P2_1,P2_3,P2_5,P2_8,P3_Entry,P3_2,P3_3,P3_5,P4_3,P4_5,P4_8,P5_7,P5_10,P6_Check,P6_6,P6_10,P7_6,P7_7 decisionNode

    %% 违规检测节点
    class P4_Violation,P5_Violation,P6_1,P7_2,P8_1,V1,V2,V3,V4 violationNode

    %% 上下文说明节点
    class P1_Jump,P4_Mode,P4_Context,P5_Context,P6_Context,P6_Route,P7_Context,P7_Level,P7_Route,P8_Context,P6_Qual,P7_Stuck,P8_Cleanup,C_Fields contextNode

    %% 开始结束节点
    class Start startNode
    class P2_Skip,P3_Skip,P4_SkipExec skipNode
    class P6_Fail,P6_Error,C_Warning errorNode
    class End endNode

    %% 额外节点
    class P7_User,P7_Escalate optionalNode

    %% 可选阶段容器
    class P2,P3 optionalNode

    %% 附录节点
    class Appendix contextNode

    %% 全局连线样式（适配深色背景）
    linkStyle default stroke:#94a3b8,stroke-width:1.5px
