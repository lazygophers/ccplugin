{
  "simple-bug-fix": {
    "name": "简单 Bug 修复",
    "description": "测试完整的 bug 修复工作流",
    "prompt": "/task:flow 修复登录验证逻辑错误",
    "allowed_tools": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "Bash",
      "AskUserQuestion"
    ],
    "expectations": {
      "state_transitions": [
