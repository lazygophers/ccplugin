{
  "name": "Bug 修复",
  "task_type": "bug-fix",
  "subtask_pattern": [
    {
      "id": "locate",
      "description": "定位问题根因",
      "goal": "通过日志、堆栈追踪或代码分析定位 Bug 根因",
      "estimated_complexity": "medium",
      "dependencies": []
    },
    {
      "id": "fix",
      "description": "实现修复",
