{
  "$schema": "task-plan-template",
  "description": "Plan 阶段模板，用于预定义常见任务类型的子任务拆分模式",
  "templates": {
    "bug-fix": {
      "name": "Bug 修复",
      "subtask_pattern": [
        {
          "id": "locate",
          "description": "定位问题根因",
          "goal": "通过日志、堆栈追踪或代码分析定位 Bug 根因",
          "estimated_complexity": "medium",
          "dependencies": []
        },
        {
          "id": "fix",
          "description": "实现修复",
          "goal": "修复定位到的问题，确保最小化改动",
          "estimated_complexity": "medium",
          "dependencies": ["locate"]
        },
        {
          "id": "verify",
          "description": "验证修复",
          "goal": "运行相关测试，确认问题已修复且无回归",
          "estimated_complexity": "low",
          "dependencies": ["fix"]
        }
      ]
    },
    "new-feature": {
      "name": "新功能开发",
      "subtask_pattern": [
        {
          "id": "design",
          "description": "接口/数据结构设计",
          "goal": "设计功能的接口、数据结构和交互流程",
          "estimated_complexity": "medium",
          "dependencies": []
        },
        {
          "id": "implement",
          "description": "核心实现",
          "goal": "实现功能的核心逻辑",
          "estimated_complexity": "high",
          "dependencies": ["design"]
        },
        {
          "id": "test",
          "description": "编写测试",
          "goal": "为新功能编写测试，覆盖正常路径和边界条件",
          "estimated_complexity": "medium",
          "dependencies": ["implement"]
        }
      ]
    },
    "refactor": {
      "name": "代码重构",
      "subtask_pattern": [
        {
          "id": "analyze",
          "description": "分析现有代码",
          "goal": "理解现有代码结构、依赖关系和调用者",
          "estimated_complexity": "medium",
          "dependencies": []
        },
        {
          "id": "refactor",
          "description": "执行重构",
          "goal": "按计划重构代码，保持外部行为不变",
          "estimated_complexity": "high",
          "dependencies": ["analyze"]
        },
        {
          "id": "verify",
          "description": "验证行为不变",
          "goal": "运行所有相关测试，确认行为未改变",
          "estimated_complexity": "low",
          "dependencies": ["refactor"]
        }
      ]
    }
  }
}
