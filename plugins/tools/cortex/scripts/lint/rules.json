{
  "version": 1,
  "rules": [
    {
      "id": "fm-missing-type",
      "severity": "error",
      "description": "frontmatter 缺 type 字段",
      "autofix": true
    },
    {
      "id": "fm-missing-created",
      "severity": "warn",
      "description": "frontmatter 缺 created 字段",
      "autofix": true
    },
    {
      "id": "fm-duplicate-tags",
      "severity": "warn",
      "description": "frontmatter tags 列表内重复",
      "autofix": true
    },
    {
      "id": "fm-banned-tags",
      "severity": "warn",
      "description": "frontmatter tags 含结构标记 (index/meta/template/_index/stub 等非内容相关)",
      "autofix": true
    },
    {
      "id": "fm-banned-fields",
      "severity": "warn",
      "description": "frontmatter 含禁止字段 (preset 等不属 page, autofix: pop)",
      "autofix": true
    },
    {
      "id": "fm-missing-tags",
      "severity": "warn",
      "description": "frontmatter tags 字段缺失或数量 < 10 (autofix: 读 fm + 正文派生 ≥10 tag, 严禁占位符)",
      "autofix": true
    },
    {
      "id": "dead-wikilink",
      "severity": "error",
      "description": "wikilink 指向不存在的页",
      "autofix": true
    },
    {
      "id": "orphan-page",
      "severity": "warn",
      "description": "无入链且无 tag 的孤儿页",
      "autofix": true
    },
    {
      "id": "duplicate-alias",
      "severity": "error",
      "description": "alias 跨页冲突",
      "autofix": true
    },
    {
      "id": "hot-too-long",
      "severity": "warn",
      "description": "hot.md 超 200 行",
      "autofix": true
    },
    {
      "id": "index-missing-section",
      "severity": "warn",
      "description": "index.md 未包含某 wiki 顶级子目录",
      "autofix": true
    },
    {
      "id": "title-h1-mismatch",
      "severity": "warn",
      "description": "H1 与 frontmatter title 不一致",
      "autofix": true
    },
    {
      "id": "filename-illegal",
      "severity": "error",
      "description": "文件名含非法字符或与 alias 冲突",
      "autofix": false
    },
    {
      "id": "block-id-duplicate",
      "severity": "error",
      "description": "block-id 重复 (^cortex-<sha8>)",
      "autofix": true
    },
    {
      "id": "callout-unknown-type",
      "severity": "warn",
      "description": "callout 类型不在 13 类白名单",
      "autofix": true
    },
    {
      "id": "path-naming-violation",
      "severity": "warn",
      "description": "业务目录命名应来自 vault.lang 的 dirs map (prd §9; 共享根/时间目录跳过)",
      "autofix": true
    },
    {
      "id": "i18n-frontmatter-lang-mismatch",
      "severity": "warn",
      "description": "页 frontmatter lang 与 vault _meta/version.json:.lang 不一致",
      "autofix": false
    },
    {
      "id": "i18n-path-not-in-locale",
      "severity": "warn",
      "description": "业务目录名不在 vault.lang 的 dirs map (autofix: slug-safe rename)",
      "autofix": true
    },
    {
      "id": "vault-structure-violation",
      "severity": "error",
      "description": "vault 根或子目录含非 preset schema 允许的文件/文件夹 (autofix: mv 到 ~/.cache/cortex/lint-backup)",
      "autofix": true
    },
    {
      "id": "vault-misaligned",
      "severity": "warn",
      "description": "vault 内 plugin-managed 文件 (seed/_meta/_templates) 内容偏离 plugin 源, 强制覆盖头部, TEMPLATE_END 后用户内容保留",
      "autofix": true
    },
    {
      "id": "repo-path-deprecated",
      "severity": "warn",
      "description": "知识库/来源/代码仓库/<host>/<org>/<repo>/ 路径已废弃, autofix mv 到 知识库/项目/<host>/<org>/<repo>/",
      "autofix": true
    },
    {
      "id": "kb-reflection-path-deprecated",
      "severity": "warn",
      "description": "知识库/反思/ 已废弃, autofix mv 到 知识库/收件箱/<basename>.md (待 digest 重分配)",
      "autofix": true
    },
    {
      "id": "kb-question-fleeting-path-deprecated",
      "severity": "warn",
      "description": "知识库/问题/ 与 知识库/临时/ 已废弃, autofix mv 到 知识库/收件箱/<basename>.md",
      "autofix": true
    },
    {
      "id": "kb-entity-concept-path-deprecated",
      "severity": "warn",
      "description": "知识库/实体/ 与 知识库/概念/ 已废弃, 应迁到 知识库/领域/<域>/<kebab>.md (warn only, 需 AI 选域, lint 不自决)",
      "autofix": false
    },
    {
      "id": "kb-journal-multi-freq-deprecated",
      "severity": "warn",
      "description": "知识库/日记/{周|月|年}/ 已废弃 (仅日维度保留), autofix mv 到 归档/日记/<YYYY-QN>.md 季度桶",
      "autofix": true
    },
    {
      "id": "kb-source-non-repo-path-deprecated",
      "severity": "warn",
      "description": "知识库/来源/{网页|论文|书籍}/ 已废弃, autofix mv 到 知识库/收件箱/<host>-<slug>.md (待 digest 分发)",
      "autofix": true
    }
  ]
}
