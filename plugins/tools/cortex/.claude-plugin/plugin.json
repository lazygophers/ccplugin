{
  "name": "cortex",
  "description": "Cortex — Obsidian 知识库协作插件: hooks 注入、CLI/MCP 操作、模板/lint/refactor、SessionStart 协作约定 + Stop 自动落档",
  "author": {
    "name": "lazygophers",
    "email": "admin@lazygophers.dev",
    "url": "https://github.com/lazygophers"
  },
  "homepage": "https://github.com/lazygophers/ccplugin/tree/master/plugins/tools/cortex",
  "repository": "https://github.com/lazygophers/ccplugin/tree/master/plugins/tools/cortex",
  "license": "AGPL-3.0-or-later",
  "agents": [
    "./agents/cortex-archivist.md",
    "./agents/cortex-cartographer.md",
    "./agents/cortex-curator.md",
    "./agents/cortex-historian.md",
    "./agents/cortex-linker.md",
    "./agents/cortex-researcher.md",
    "./agents/cortex-summarizer.md",
    "./agents/cortex-translator.md"
  ],
  "skills": [
    "./skills/cortex-canvas",
    "./skills/cortex-dashboard",
    "./skills/cortex-doctor",
    "./skills/cortex-ingest",
    "./skills/cortex-ingest-bulk",
    "./skills/cortex-install",
    "./skills/cortex-lint",
    "./skills/cortex-locale",
    "./skills/cortex-new",
    "./skills/cortex-refactor",
    "./skills/cortex-save",
    "./skills/cortex-search",
    "./skills/cortex-session"
  ],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/plugins/marketplaces/ccplugin-market/plugins/tools/cortex//hooks/session_start.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/plugins/marketplaces/ccplugin-market/plugins/tools/cortex//hooks/stop.sh",
            "async": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/plugins/marketplaces/ccplugin-market/plugins/tools/cortex//hooks/stop.sh",
            "async": true
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/plugins/marketplaces/ccplugin-market/plugins/tools/cortex//hooks/post_compact.sh",
            "async": true
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "cortex": {
      "command": "cortex-mcp",
      "args": [],
      "env": {
        "CORTEX_VAULT_PATH": "${CORTEX_VAULT_PATH:-}",
        "CORTEX_PLUGIN_ROOT": "~/.claude/plugins/marketplaces/ccplugin-market/plugins/tools/cortex/"
      }
    }
  },
  "keywords": [
    "obsidian",
    "knowledge-base",
    "pkm",
    "wiki",
    "zettelkasten",
    "lyt",
    "para",
    "second-brain",
    "auto-archive",
    "session-recap"
  ]
}
