{
  "mcpServers": {
    "duckduckgo": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@oevortex/ddg_search"
      ],
      "env": {
        "ALL_PROXY": "${PROXY_URL}",
        "HTTPS_PROXY": "${PROXY_URL}",
        "HTTP_PROXY": "${PROXY_URL}"
      },
      "metadata": {
        "description": "网络搜索引擎 - agentic-retriever核心依赖",
        "priority": "required",
        "usage": "信息检索、技术文档搜索、市场数据"
      }
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "env": {},
      "metadata": {
        "description": "复杂推理引擎 - 增强架构分析和决策能力",
        "priority": "required",
        "usage": "架构评审、技术选型、复杂问题分析"
      }
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {},
      "metadata": {
        "description": "文档检索增强 - 最新文档和API参考",
        "priority": "optional",
        "usage": "框架文档、API参考、官方指南"
      }
    },
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--acceptInsecureCerts",
        "--proxy-server=${PROXY_URL}"
      ],
      "env": {},
      "metadata": {
        "description": "浏览器自动化 - 可选，用于需要截图或交互式测试场景",
        "priority": "optional",
        "usage": "UI测试、页面截图、交互式调试"
      }
    }
  }
}
