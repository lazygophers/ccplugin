{
    "name": "skein",
    "description": "SKEIN — 独立任务管理插件 (零 trellis 依赖, 自带 .skein/ 工作区): 强制 task 闭环 (plan→exec→check→finish) + 动态 DAG 编排调度 (冲突自算边 + depends_on, 并发上限 2, task 级 + subtask 级双层) + worktree 隔离 + task.md 看板; 差异化核心是两层×类目规则记忆 (基于 .skein/spec): core 常驻注入硬规 + recall 按需语义召回, 层内按类目 (git/test/arch/build...) 分子目录, task finish 后经 sediment 判定门沉淀学习。含 9 skill (setup 初始化+结构维护 (trellis 迁移为其一场景) / flow 强制闭环 (委托各阶段 skill) / plan 规划真值源+用户可调入口 (无参停在 start 前只规划) +破坏式重构 / exec 执行编排调度真值源 (双层 DAG / 完成即派 / 并发 2, flow exec 委托) / memory 记忆+空仓播种 (绑定 skein-specer) / grill 对抗审查 / check 质量门+一致性核查 (冲突→深化拆分) +第3轮根因复盘 / finish 收尾编排门 (勘察+sediment+清理+archive) / clean 归档清理) + 6 agent (skein-executor 默认执行器兜底执行任意 subtask / skein-setup 初始化迁移 / skein-checker 验证+一致性核查 / skein-researcher 调研 / skein-finisher 收尾勘察 / skein-specer 记忆员 recall+sediment草案, 均无 Agent/Task 工具做递归护栏); exec subtask 由 main 为每个 subtask 选合适 agent (无则 skein-executor) 执行, 经 dispatch prompt 强制递归护栏+读后写硬门; SessionStart hook 注入 core 规则索引 + SubagentStart hook 给执行 agent 注入 core 全文+spec 纪律 + PreToolUse hook 硬阻 AI 直接读写 .skein/ 的 task.json / task.md (顶层 + per-task, 全由脚本维护, subtask DAG 状态经脚本命令取)",
    "author": {
        "name": "lazygophers",
        "email": "admin@lazygophers.dev",
        "url": "https://github.com/lazygophers"
    },
    "homepage": "https://github.com/lazygophers/ccplugin/tree/master/plugins/tools/skein",
    "repository": "https://github.com/lazygophers/ccplugin/tree/master/plugins/tools/skein",
    "license": "AGPL-3.0-or-later",
    "userConfig": {
        "max_active": {
            "type": "number",
            "title": "最大并行 task 数",
            "description": "同 session 同时 in_progress 的 task 上限。推荐 2 (与 subtask 级并发一致)。覆盖 .skein/config.yaml。",
            "default": 2,
            "min": 1,
            "max": 8
        },
        "max_parallel": {
            "type": "number",
            "title": "最大并行 subtask 数",
            "description": "单 task 内同时跑的 subtask 上限。推荐 2。覆盖 .skein/config.yaml。",
            "default": 2,
            "min": 1,
            "max": 8
        }
    },
    "skills": [
        "./skills/skein-setup",
        "./skills/skein-flow",
        "./skills/skein-plan",
        "./skills/skein-exec",
        "./skills/skein-spec",
        "./skills/skein-grill",
        "./skills/skein-check",
        "./skills/skein-finish",
        "./skills/skein-clean"
    ],
    "agents": [
        "./agents/skein-setup.md",
        "./agents/skein-checker.md",
        "./agents/skein-researcher.md",
        "./agents/skein-executor.md",
        "./agents/skein-finisher.md",
        "./agents/skein-specer.md",
        "./agents/skein-dedup.md"
    ],
    "commands": [
        "./commands/skein-doctor.md"
    ],
    "keywords": [
        "task-management",
        "task-orchestration",
        "dag-scheduling",
        "worktree",
        "sub-agent",
        "rules-memory",
        "kanban",
        "standalone"
    ],
    "experimental": {
        "monitors": [
            {
                "name": "skein-board-server",
                "description": "SKEIN 看板持久 web 服务 (随机 port); config.yaml web_serve=false 则自动 no-op 退出",
                "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/skein.py serve --auto",
                "when": "always"
            }
        ],
        "themes": "./themes/"
    },
    "hooks": {
        "SessionStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "${CLAUDE_PLUGIN_ROOT}/bin/skein-spec session-start",
                        "timeout": 5
                    },
                    {
                        "type": "command",
                        "command": "${CLAUDE_PLUGIN_ROOT}/bin/skein session-context",
                        "timeout": 5
                    },
                    {
                        "type": "command",
                        "command": "cd ${CLAUDE_PLUGIN_ROOT} && (pip3 install -q -r requirements.txt >/dev/null 2>&1 &)",
                        "timeout": 5
                    }
                ]
            }
        ],
        "UserPromptSubmit": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "${CLAUDE_PLUGIN_ROOT}/bin/skein user-prompt",
                        "timeout": 5
                    }
                ]
            }
        ],
        "SubagentStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "${CLAUDE_PLUGIN_ROOT}/bin/skein-spec subagent-start",
                        "timeout": 5
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "Edit|Write|MultiEdit|Read",
                "hooks": [
                    {
                        "type": "command",
                        "command": "${CLAUDE_PLUGIN_ROOT}/bin/skein-hooks guard",
                        "timeout": 5
                    }
                ]
            }
        ],
        "PermissionRequest": [
            {
                "matcher": "Bash|Edit|Write|Read",
                "hooks": [
                    {
                        "type": "command",
                        "command": "${CLAUDE_PLUGIN_ROOT}/bin/skein-hooks permission",
                        "timeout": 5
                    }
                ]
            }
        ],
        "PermissionDenied": [
            {
                "matcher": "Bash|Edit|Write|Read",
                "hooks": [
                    {
                        "type": "command",
                        "command": "${CLAUDE_PLUGIN_ROOT}/bin/skein-hooks permission",
                        "timeout": 5
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Edit|Write|MultiEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "${CLAUDE_PLUGIN_ROOT}/bin/skein-hooks fmt",
                        "timeout": 15
                    },
                    {
                        "type": "command",
                        "command": "${CLAUDE_PLUGIN_ROOT}/bin/skein-hooks spec-meta",
                        "timeout": 10
                    }
                ]
            }
        ],
        "PostToolBatch": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "${CLAUDE_PLUGIN_ROOT}/bin/skein-hooks batch",
                        "timeout": 5
                    }
                ]
            }
        ],
        "PostToolUseFailure": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "${CLAUDE_PLUGIN_ROOT}/bin/skein-hooks report",
                        "timeout": 5
                    }
                ]
            }
        ]
    }
}