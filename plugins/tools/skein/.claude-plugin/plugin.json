{
  "name": "skein",
  "description": "SKEIN — 独立任务管理插件 (零 trellis 依赖, 自带 .skein/ 工作区): 强制 task 闭环 (plan→exec→check→finish) + 动态 DAG 编排调度 (冲突自算边 + depends_on, 并发上限 2, task 级 + subtask 级双层) + worktree 隔离 + task.md 看板; 差异化核心是两层×类目规则记忆 (基于 .claude/rules): core 常驻注入硬规 + recall 按需语义召回, 层内按类目 (git/test/arch/build...) 分子目录, task finish 后经 sediment 判定门沉淀学习。含 9 skill (flow 强制闭环 / orchestrate 双层编排 / workspace 看板 / planning 规划入口 / memory 记忆 / grill 对抗审查 / spec 破坏式重构 / check 质量门 / clean 归档清理) + 3 agent (skein-implementer 执行 / skein-checker 验证 / skein-researcher 调研, 均无 Agent/Task 工具做递归护栏); SessionStart hook 注入 core 规则 + PreToolUse hook 硬阻直编 task.md / 直接读写 state.json",
  "author": {
    "name": "lazygophers",
    "email": "admin@lazygophers.dev",
    "url": "https://github.com/lazygophers"
  },
  "homepage": "https://github.com/lazygophers/ccplugin/tree/master/plugins/tools/skein",
  "repository": "https://github.com/lazygophers/ccplugin/tree/master/plugins/tools/skein",
  "license": "AGPL-3.0-or-later",
  "skills": [
    "./skills/skein-flow",
    "./skills/skein-orchestrate",
    "./skills/skein-workspace",
    "./skills/skein-planning",
    "./skills/skein-memory",
    "./skills/skein-grill",
    "./skills/skein-spec",
    "./skills/skein-check",
    "./skills/skein-clean"
  ],
  "agents": [
    "./agents/skein-implementer.md",
    "./agents/skein-checker.md",
    "./agents/skein-researcher.md"
  ],
  "commands": [
    "./commands/skein-go.md"
  ],
  "keywords": [
    "task-management",
    "task-orchestration",
    "dag-scheduling",
    "worktree",
    "sub-agent",
    "rules-memory",
    "kanban",
    "standalone"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/memory.py session-start",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/skein.py session-context",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/guard-skein.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
