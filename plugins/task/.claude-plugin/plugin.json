{
  "name": "task",
  "description": "任务管理插件 - 创建和管理开发任务",
  "version": "0.2.0",
  "author": {
    "name": "lazygophers"
  },
  "license": "MIT",
  "homepage": "https://github.com/lazygophers/ccplugin/tree/main/plugins/task",
  "repository": "https://github.com/lazygophers/ccplugin",
  "agents": [
    "./agents/task-planner.md",
    "./agents/task-decomposer.md"
  ],
  "skills": "./skills/",
  "hooks": "./hooks/hooks.json",
  "mcpServers": {
    "task-server": {
      "command": "uv",
      "args": ["run", "python", "-m", "task.server"],
      "env": {
        "LOG_LEVEL": "info",
        "PYTHONUNBUFFERED": "1"
      }
    }
  }
}
